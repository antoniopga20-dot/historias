---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import PostCard from "../components/PostCard.astro";
import CategoryCard from "../components/CategoryCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { categories } from "../data/categories";
import { site, welcome } from "../data/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest = posts.slice(0, 4);
const featuredCategories = categories.filter((c) => c.featured).slice(0, 6);
---
<BaseLayout
  title={undefined}
  description={welcome.short}
>
  <HeroCarousel />

  <section class="section">
    <Container width="narrow">
      <p class="eyebrow">Bienvenida</p>
      <p style="font-family: var(--font-serif); font-size: var(--fs-xl); line-height:1.45; color: var(--color-ink); max-width: 60ch; margin: 0 0 var(--space-5) 0;">
        {welcome.long}
      </p>
      <p class="muted" style="max-width: 60ch;">
        Soy <strong style="color: var(--color-ink);">{site.author}</strong>.
        Esta página reúne, poco a poco, mis textos, materiales y referencias de
        trabajo. Si es la primera vez que llegas, quizás te interese empezar
        por <a href="/sobre-mi">Sobre mí</a> o por el <a href="/blog">blog</a>.
      </p>
    </Container>
  </section>

  <section class="section section--alt">
    <Container>
      <SectionTitle
        eyebrow="Últimas entradas"
        title="Del cuaderno"
        lead="Las publicaciones más recientes del blog."
      />
      <div class="grid grid--cards">
        {latest.map((p) => (
          <PostCard
            title={p.data.title}
            href={`/blog/${p.slug}`}
            date={p.data.date}
            description={p.data.description}
            category={p.data.category}
            tags={p.data.tags}
            cover={p.data.cover}
          />
        ))}
      </div>
      <p style="margin-top: var(--space-6);">
        <a class="btn btn--ghost" href="/blog">Ver todas las entradas</a>
      </p>
    </Container>
  </section>

  <section class="section">
    <Container>
      <SectionTitle
        eyebrow="Categorías principales"
        title="Por dónde se entra"
        lead="Algunos hilos temáticos que organizan el sitio."
      />
      <div class="grid grid--cards">
        {featuredCategories.map((c) => <CategoryCard category={c} />)}
      </div>
    </Container>
  </section>

  <section class="section section--alt">
    <Container width="narrow">
      <SectionTitle
        eyebrow="Cómo seguir"
        title="Sigue Historias"
        lead="Recibe nuevas entradas en tu lector de RSS o explora otras secciones del sitio."
      />
      <div style="display:flex; gap: var(--space-3); flex-wrap: wrap;">
        <a class="btn" href="/rss.xml">Suscribirme por RSS</a>
        <a class="btn btn--ghost" href="/publicaciones">Publicaciones</a>
        <a class="btn btn--ghost" href="/actividades">Actividades</a>
        <a class="btn btn--ghost" href="/contacto">Contacto</a>
      </div>
    </Container>
  </section>
</BaseLayout>

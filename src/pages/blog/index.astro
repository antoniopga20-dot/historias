---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { findCategory } from "../../data/categories";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Categorías con al menos una entrada
const usedCategories = Array.from(
  new Set(posts.map((p) => p.data.category).filter(Boolean) as string[]),
).map((slug) => findCategory(slug) ?? { slug, name: slug, description: "" });
---
<PageLayout
  title="Blog"
  eyebrow="Bitácora"
  lead="Entradas, notas y reflexiones. Filtra por categoría o navega cronológicamente."
  width="default"
>
  <div class="filters" role="navigation" aria-label="Filtrar por categoría">
    <a href="/blog" class="filter-chip is-active" data-filter="all">Todas</a>
    {usedCategories.map((c) => (
      <a href={`/blog/categoria/${c.slug}`} class="filter-chip" data-filter={c.slug}>{c.name}</a>
    ))}
  </div>

  <div class="grid grid--cards">
    {posts.map((p) => (
      <PostCard
        title={p.data.title}
        href={`/blog/${p.slug}`}
        date={p.data.date}
        description={p.data.description}
        category={p.data.category}
        tags={p.data.tags}
        cover={p.data.cover}
      />
    ))}
  </div>

  {posts.length === 0 && (
    <p class="muted">Aún no hay entradas publicadas. Vuelve pronto.</p>
  )}
</PageLayout>

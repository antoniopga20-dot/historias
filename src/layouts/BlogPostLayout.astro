---
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/Container.astro";
import { formatDate, isoDate } from "../utils/formatDate";
import { findCategory } from "../data/categories";
import { readingTime } from "../utils/readingTime";

interface Props {
  title: string;
  description?: string;
  date: Date | string;
  category?: string;
  tags?: string[];
  cover?: string;
  rawText?: string;
}
const {
  title,
  description,
  date,
  category,
  tags = [],
  cover,
  rawText = "",
} = Astro.props;

const categoryName = category ? findCategory(category)?.name ?? category : undefined;
const minutes = readingTime(rawText);
---
<BaseLayout title={title} description={description} type="article">
  <article>
    <section class="section section--alt" style="padding-block: clamp(var(--space-7), 7vw, var(--space-8));">
      <Container width="prose">
        <div class="post-header">
          <p class="post-meta">
            <time datetime={isoDate(date)}>{formatDate(date)}</time>
            {categoryName && <> · <a href={`/blog?cat=${category}`} style="color:inherit;">{categoryName}</a></>}
            <> · {minutes}</>
          </p>
          <h1>{title}</h1>
          {description && <p class="post-description">{description}</p>}
        </div>
      </Container>
    </section>

    {cover && (
      <Container width="default">
        <img src={cover} alt="" style="width:100%; max-height:520px; object-fit:cover; border-radius: var(--radius-md); margin-top: calc(-1 * var(--space-7));" />
      </Container>
    )}

    <section class="section" style="padding-top: var(--space-7);" data-pagefind-body>
      <Container width="prose">
        <div class="prose">
          <slot />
        </div>

        {tags.length > 0 && (
          <div class="post-tags">
            <span class="eyebrow">Etiquetas</span>
            <div style="margin-top: var(--space-2);">
              {tags.map((t) => <span class="tag">#{t}</span>)}
            </div>
          </div>
        )}

        <hr />

        <p class="muted" style="font-size: var(--fs-sm);">
          ¿Quieres comentar este texto o proponer una conversación?
          <a href="/contacto">Escríbeme</a>.
        </p>
      </Container>
    </section>
  </article>
</BaseLayout>

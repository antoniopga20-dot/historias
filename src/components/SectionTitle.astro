---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: "left" | "center";
  as?: "h1" | "h2" | "h3";
}
const { eyebrow, title, lead, align = "left", as: Tag = "h2" } = Astro.props;
const style = align === "center" ? "text-align:center; margin-inline:auto;" : "";
---
<header class="section-title" style={`max-width:740px; margin-bottom: var(--space-6); ${style}`}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <Tag style="margin-bottom: var(--space-3);">{title}</Tag>
  {lead && <p class="muted" style="font-size: var(--fs-md); margin: 0;">{lead}</p>}
</header>
